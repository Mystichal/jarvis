{
	"name": "Jarvis",
	"description": "Jarvis API Client",
	"keywords": ["Jarvis", "API", "Client"],
	"license": "MIT",
	"type": "project",
	"require": {
		"php": ">=7.0.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^7"
	},
	"autoload": {
		"classmap": [
			"app/controllers",
			"app/core"
		],
		"psr-4": {
			"App\\": "app"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"config": {
		"preferred-install": "dist",
		"sort-packages": true,
		"optimize-autoloader": true
	}
}
